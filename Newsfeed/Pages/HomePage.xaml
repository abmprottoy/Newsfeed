<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Newsfeed.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Newsfeed.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Newsfeed.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid
        x:Name="PageLayoutRoot"
        Padding="24,18,24,24"
        SizeChanged="PageLayoutRoot_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="IntroRow" Height="Auto" />
            <RowDefinition x:Name="IntroSpacerRow" Height="16" />
            <RowDefinition x:Name="SummaryRow" Height="Auto" />
            <RowDefinition x:Name="ContentSpacerRow" Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            x:Name="IntroSection"
            Spacing="4">
            <TextBlock
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="Live ticker" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Monitor the latest headlines and jump into the stories that matter most."
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid
            x:Name="SummarySection"
            Grid.Row="2"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                x:Name="SummaryTextSection"
                Spacing="4"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="{Binding FocusLine}" />
                <TextBlock
                    x:Name="SourcesTextBlock"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding SourcesLine}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <StackPanel
                x:Name="SummaryActionsSection"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Top">
                <Button
                    x:Name="ScrollModeButton"
                    Click="ScrollModeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Back" />
                        <TextBlock Text="Scroll" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="StackModeButton"
                    Click="StackModeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Up" />
                        <TextBlock Text="Slide" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="CompactViewButton"
                    Click="CompactViewButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="FullScreen" />
                        <TextBlock
                            x:Name="CompactViewButtonText"
                            Text="Compact: Off" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid
            x:Name="ContentSection"
            Grid.Row="4"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeadlinesColumn" Width="360" />
                <ColumnDefinition x:Name="TickerColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="HeadlinesPane"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="18,16,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="Live updates" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding StatusLine}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <Button
                            x:Name="RefreshButton"
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="RefreshButton_Click"
                            ToolTipService.ToolTip="Refresh">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="HeadlinesList"
                        Grid.Row="1"
                        ItemsSource="{Binding Headlines}"
                        SelectedItem="{Binding SelectedHeadline, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:NewsHeadline">
                                <Grid Padding="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind SourceName}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind RelativePublishedText}" />
                                    <TextBlock
                                        Grid.ColumnSpan="2"
                                        Grid.Row="1"
                                        Margin="0,4,0,0"
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        MaxLines="2"
                                        Text="{x:Bind Title}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="WrapWholeWords" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border
                x:Name="TickerPane"
                Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
                <Border
                    Background="Transparent"
                    CornerRadius="6"
                    MinHeight="120">
                    <Grid>
                        <controls:ContinuousTickerControl
                            x:Name="ContinuousTicker"
                            Headlines="{Binding Headlines}"
                            PointerPressed="Ticker_PointerPressed"
                            SelectedHeadline="{Binding SelectedHeadline}" />
                        <controls:VerticalTickerControl
                            x:Name="VerticalTicker"
                            Headlines="{Binding Headlines}"
                            PointerPressed="Ticker_PointerPressed"
                            SelectedHeadline="{Binding SelectedHeadline}"
                            Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Page>
