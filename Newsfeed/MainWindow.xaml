<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Newsfeed.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Newsfeed">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootLayout"
        Background="Transparent"
        PointerPressed="RootLayout_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Margin="8,0,16,0"
            BackRequested="AppTitleBar_BackRequested"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="False"
            Title="Iran Watch"
            Subtitle="{x:Bind ViewModel.TitleBarSubtitle, Mode=OneWay}">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE774;" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="RootNavigationView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="True"
            IsTitleBarAutoPaddingEnabled="False"
            AlwaysShowHeader="False"
            Background="Transparent"
            PaneDisplayMode="Left"
            BackRequested="RootNavigationView_BackRequested"
            SelectionChanged="RootNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="HomeNavigationItem"
                    Content="Newsfeed"
                    Tag="home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
