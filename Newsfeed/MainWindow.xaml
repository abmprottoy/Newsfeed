<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Newsfeed.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Newsfeed.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Newsfeed.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Newsfeed">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootLayout"
        Background="Transparent"
        Padding="16,10,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Iran Watch"
            Subtitle="{x:Bind ViewModel.TitleBarSubtitle, Mode=OneWay}">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE774;" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="{x:Bind ViewModel.FocusLine, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.SourcesLine, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Top">
                <Button
                    x:Name="ScrollModeButton"
                    Click="ScrollModeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Back" />
                        <TextBlock Text="Scroll" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="StackModeButton"
                    Click="StackModeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Up" />
                        <TextBlock Text="Slide" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="16,14,16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="Live updates" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.StatusLine, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            Opacity="0"
                            Text=" " />
                        <Button
                            x:Name="RefreshButton"
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="RefreshButton_Click"
                            ToolTipService.ToolTip="Refresh">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="HeadlinesList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Headlines, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedHeadline, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:NewsHeadline">
                                <Grid Padding="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind SourceName}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind RelativePublishedText}" />
                                    <TextBlock
                                        Grid.ColumnSpan="2"
                                        Grid.Row="1"
                                        Margin="0,4,0,0"
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        MaxLines="2"
                                        Text="{x:Bind Title}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="WrapWholeWords" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
                <Border
                    Background="Transparent"
                    CornerRadius="10"
                    MinHeight="120">
                    <Grid>
                        <controls:ContinuousTickerControl
                            x:Name="ContinuousTicker"
                            Headlines="{x:Bind ViewModel.Headlines, Mode=OneWay}"
                            PointerPressed="Ticker_PointerPressed"
                            SelectedHeadline="{x:Bind ViewModel.SelectedHeadline, Mode=OneWay}" />
                        <controls:VerticalTickerControl
                            x:Name="VerticalTicker"
                            Headlines="{x:Bind ViewModel.Headlines, Mode=OneWay}"
                            PointerPressed="Ticker_PointerPressed"
                            SelectedHeadline="{x:Bind ViewModel.SelectedHeadline, Mode=OneWay}"
                            Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
