<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Newsfeed.Controls.ContinuousTickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        Loaded="RootGrid_Loaded"
        SizeChanged="RootGrid_SizeChanged"
        Unloaded="RootGrid_Unloaded">
        <Grid.Clip>
            <RectangleGeometry x:Name="ClipGeometry" />
        </Grid.Clip>

        <Canvas VerticalAlignment="Center">
            <StackPanel
                x:Name="TickerPanel"
                Orientation="Horizontal"
                Spacing="60">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="TickerTransform" />
                </StackPanel.RenderTransform>

                <TextBlock
                    x:Name="TickerText"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="White"
                    TextTrimming="None"
                    TextWrapping="NoWrap" />
                <TextBlock
                    x:Name="TickerCloneText"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="White"
                    TextTrimming="None"
                    TextWrapping="NoWrap" />
            </StackPanel>
        </Canvas>
    </Grid>
</UserControl>
