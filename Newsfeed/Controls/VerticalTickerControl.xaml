<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Newsfeed.Controls.VerticalTickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        Loaded="RootGrid_Loaded"
        SizeChanged="RootGrid_SizeChanged"
        Unloaded="RootGrid_Unloaded">
        <Grid.Clip>
            <RectangleGeometry x:Name="ClipGeometry" />
        </Grid.Clip>

        <Border VerticalAlignment="Center">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CurrentTransform" />
            </Border.RenderTransform>
            <TextBlock
                x:Name="CurrentText"
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="White"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </Border>

        <Border VerticalAlignment="Center" Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="IncomingTransform" Y="54" />
            </Border.RenderTransform>
            <TextBlock
                x:Name="IncomingText"
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="White"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </Border>
    </Grid>
</UserControl>
